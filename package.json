{
  "name": "imagic-auth",
  "version": "1.0.1",
  "description": "JWT signing/verification, API key utilities, and permission checking for Node.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "files": ["src", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "test": "node --test ./tests/**/*.test.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "engines": { "node": ">=24" },
  "keywords": ["imagic", "auth", "jwt", "api-key", "permissions"],
  "author": "iMagicKey",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "latest",
    "chai": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-import": "latest",
    "eslint-plugin-n": "latest",
    "eslint-plugin-prettier": "latest",
    "eslint-plugin-promise": "latest",
    "globals": "latest",
    "prettier": "latest"
  }
}
